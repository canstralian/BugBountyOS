# Copy to .env and fill in real values. .env is gitignored.

# Pipeline / storage Flask apps
FLASK_ENV=development
SQLALCHEMY_DATABASE_URI=sqlite:///pipeline.db

# Dashboard (Drizzle / Neon)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Airtable scope adapter
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
